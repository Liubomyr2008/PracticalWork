#include <stdio.h> //Практика 9
#include <math.h>

int main() {
    long long x, y;
    long long d;
    long long k;

    printf("Введіть x і y: ");
    scanf("%lld %lld", &x, &y);

    d = y - x;

    if (d == 0) {
        printf("Мінімальна кількість кроків: 0\n");
        return 0;
    }

    k = (long long)sqrt((double)d);

    if (k * k == d)
        printf("Мінімальна кількість кроків: %lld\n", 2 * k - 1);
    else if (d <= k * k + k)
        printf("Мінімальна кількість кроків: %lld\n", 2 * k);
    else
        printf("Мінімальна кількість кроків: %lld\n", 2 * k + 1);

    return 0;
}
