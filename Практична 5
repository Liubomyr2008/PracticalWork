#include <stdio.h> //практика 5

#define MOD 12345

int main() {
    int n;

    printf("Введіть довжину послідовності: ");
    scanf("%d", &n);

    int dp0 = 1, dp1 = 1, dp2 = 0;

    for (int i = 2; i <= n; i++) {
        int new0 = (dp0 + dp1 + dp2) % MOD;
        int new1 = dp0 % MOD;
        int new2 = dp1 % MOD;

        dp0 = new0;
        dp1 = new1;
        dp2 = new2;
    }

    int result = (dp0 + dp1 + dp2) % MOD;

    printf("Кількість шуканих послідовностей: %d\n", result);

    return 0;
}
